// Corpus: anyhow + thiserror — typed error enums and context chains that
// must surface as catchable Python RuntimeErrors, never dead workers.

use anyhow::{Context, Result};
use thiserror::Error;

#[derive(Error, Debug)]
enum LedgerError {
  #[error("account {0} is frozen")]
  Frozen(String),
  #[error("insufficient funds: need {need}, have {have}")]
  Insufficient { need: i64, have: i64 },
}

fn withdraw(account: String, balance: i64, amount: i64) -> Result<i64> {
  if account.starts_with("frozen") {
    return Err(LedgerError::Frozen(account)).context("withdrawal rejected");
  }
  if amount > balance {
    return Err(LedgerError::Insufficient { need: amount, have: balance })
      .context("withdrawal rejected");
  }
  Ok(balance - amount)
}

const remaining = withdraw("acct-9", 100, 30)

caught = ""
try:
    withdraw("frozen-1", 100, 1)
except RuntimeError as e:
    caught = e.message

fn explode(tag: String) -> i64 {
  panic!("kaboom {tag}")
}

panic_caught = ""
try:
    explode("now")
except RuntimeError as e:
    panic_caught = e.message

print(f"remaining={remaining} caught_frozen={'frozen' in caught} panic_caught={'kaboom now' in panic_caught}")
