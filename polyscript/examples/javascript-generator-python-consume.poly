closed = []
produced = []

function* js_rows(label) {
  try {
    for (const value of [0, 1, 2, 3]) {
      produced.push(value)
      yield {"items": value, "close": label}
    }
  } finally {
    closed.push(label)
  }
}

labels = []
for row in js_rows("break"):
  labels.append(f"{row.items}:{row.close}")
  if len(labels) == 2:
    break

print(f"JavaScript generator Python consume {'|'.join(labels)}")
console.log(`JavaScript generator Python closed ${closed.join("|")}`)
console.log(`JavaScript generator Python produced ${produced.join("|")}`)
