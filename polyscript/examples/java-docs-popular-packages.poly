// Docs-style Java package usage: Gson JSON, jsoup HTML parsing, OkHttp request
// construction, and Apache Commons CSV parsing.

const json_name = new com.google.gson.Gson().fromJson(new com.google.gson.Gson().toJson(java.util.Map.of("name", "Ada", "age", 37)), java.util.Map.class).get("name")
const link = org.jsoup.Jsoup.parse("<html><body><p>Poly</p><a href=\"/docs\">Docs</a></body></html>").select("a").first().attr("href")
const host = new okhttp3.Request.Builder().url("https://example.com/docs").build().url().host()
const records = org.apache.commons.csv.CSVFormat.DEFAULT.builder().setHeader().setSkipHeaderRecord(true).build().parse(new java.io.StringReader("name,score\nada,10\ngrace,12")).getRecords().size()

print(f"Java docs packages {json_name} {link} {host} {records}")
