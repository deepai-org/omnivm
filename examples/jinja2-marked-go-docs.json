{
  "version": 1,
  "defaultRuntime": "javascript",
  "ops": [
    {
      "op": "import",
      "path": "jinja2",
      "runtime": "python",
      "bind": "jinja2"
    },
    {
      "op": "import",
      "path": "marked",
      "runtime": "javascript",
      "defaultImport": "marked"
    },
    {
      "op": "func_def",
      "name": "content_key",
      "params": [
        {
          "name": "slug"
        },
        {
          "name": "html"
        }
      ],
      "body": [],
      "bodyRuntime": "go",
      "source": "package polyfunc\n\nimport (\n\t\"crypto/sha256\"\n\t\"fmt\"\n\t\"strings\"\n)\n\nfunc ContentKey(slug interface{}, html interface{}) interface{} {\n\tslug_string := slug.(string)\n\thtml_string := html.(string)\n\tsanitized := strings.ReplaceAll(html_string, \"<script\", \"&lt;script\")\n\tsum := sha256.Sum256([]byte(slug_string + \":\" + sanitized))\n\tprefix := fmt.Sprintf(\"%.6x\", sum)\n\treturn slug_string + \"-\" + prefix\n}",
      "exports": [
        "ContentKey"
      ]
    },
    {
      "op": "eval",
      "runtime": "python",
      "code": "jinja2.Template(\"# Poly Docs\\\\n\\\\nThis page is rendered through multiple runtimes.\").render()",
      "bind": "markdown_source"
    },
    {
      "op": "eval",
      "runtime": "javascript",
      "code": "marked.parse(markdown_source)",
      "bind": "html",
      "captures": {
        "markdown_source": "markdown_source"
      }
    },
    {
      "op": "eval",
      "runtime": "go",
      "code": "content_key(\"poly-docs\", html)",
      "bind": "key",
      "captures": {
        "html": "html"
      }
    },
    {
      "op": "native",
      "runtime": "python",
      "code": "print(f\"Jinja2/Marked/Go docs key={key} length={len(html)}\")"
    }
  ],
  "bridges": [],
  "typeSummary": {
    "crossings": 1,
    "safe": 1,
    "coerce": 0,
    "check": 0,
    "errors": 0
  }
}
