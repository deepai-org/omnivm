{
  "version": 1,
  "defaultRuntime": "python",
  "ops": [
    {
      "op": "resource",
      "action": "open",
      "runtime": "python",
      "bind": "tx",
      "kind": "sqlalchemy.transaction",
      "disposer": "rollback"
    },
    {
      "op": "try",
      "body": [
        {
          "op": "job",
          "action": "enqueue",
          "runtime": "ruby",
          "kind": "sidekiq",
          "bind": "job",
          "payload": {"kind": "literal", "value": {"user": "ada", "task": "receipt"}}
        },
        {
      "op": "exec",
      "runtime": "javascript",
      "captures": {"tx": "tx", "job": "job"},
      "code": "const tx_meta = tx.toJSON(); const job_meta = job.toJSON(); console.log(`Edge handle proxy tx=${tx_meta.kind} closed=${tx_meta.closed} job=${job_meta.kind} done=${job_meta.done}`)"
        },
        {
          "op": "job",
          "action": "complete",
          "target": "job",
          "value": {"kind": "literal", "value": "receipt-ok"}
        },
        {
          "op": "job",
          "action": "wait",
          "target": "job",
          "bind": "job_result"
        }
      ],
      "catches": [],
      "finallyBody": [
        {
          "op": "resource",
          "action": "close",
          "target": "tx"
        }
      ]
    },
    {
      "op": "exec",
      "runtime": "javascript",
      "captures": {"tx": "tx", "job_result": "job_result"},
      "code": "const tx_meta_after = tx.toJSON(); console.log(`Edge resource closed=${tx_meta_after.closed} result=${job_result}`)"
    }
  ]
}
