    {
      "op": "eval",
      "runtime": "javascript",
      "code": "lodash.concat([], [{\"id\": 1, \"role\": \"admin\", \"active\": true}, {\"id\": 2, \"role\": \"editor\", \"active\": true}, {\"id\": 3, \"role\": \"admin\", \"active\": true}])",
      "bind": "rows"
