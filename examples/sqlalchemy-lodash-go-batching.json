      ]
    },
    {
      "op": "eval",
      "runtime": "python",
      "code": "sqlalchemy.table(\"users\", sqlalchemy.column(\"id\"), sqlalchemy.column(\"role\"), sqlalchemy.column(\"active\"))",
      "bind": "users_table"
    },
    {
      "op": "eval",
      "runtime": "python",
      "code": "str(sqlalchemy.select(users_table).where((users_table.c.active == True)))",
