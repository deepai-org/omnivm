    },
    {
      "op": "eval",
      "runtime": "python",
      "code": "len(done)",
      "bind": "delivered",
      "captures": {
        "done": "done"
      }
    },
    {
      "op": "native",
      "runtime": "python",
      "code": "print(f\"Channel contract total={total} workers={len(workers)} delivered={delivered}\")"
